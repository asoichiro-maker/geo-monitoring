# =============================================================================
# GEO モニタリング SaaS -- 環境変数テンプレート
# このファイルを .env にコピーして実際の値を設定してください
# .env は .gitignore に追加し、絶対にコミットしないこと
# =============================================================================

# -- AI API キー --------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...        # Claude API（言及判定）
OPENAI_API_KEY=sk-...               # ChatGPT
GOOGLE_API_KEY=AIza...              # Gemini
PERPLEXITY_API_KEY=pplx-...         # Perplexity (sonar-pro)
SERPAPI_KEY=...                     # SerpAPI（AI Overview取得）

# -- PostgreSQL ---------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/geo_monitor

# -- Google Sheets ------------------------------------------------------------
# サービスアカウントの JSON キーファイルへのパス
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/service_account.json

# -- Claude モデル設定（変更する場合のみ設定）----------------------------------
# MENTION_DETECTOR_MODEL=claude-haiku-4-5-20251001
# MENTION_DETECTOR_MAX_TOKENS=512

# -- SerpAPI 設定 -------------------------------------------------------------
SERPAPI_LOCALE_HL=ja
SERPAPI_LOCALE_GL=jp

# -- アラート通知 -------------------------------------------------------------
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# LOG_LEVEL=INFO
